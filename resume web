<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    scroll-behavior:smooth;
    font-family:'Poppins',sans-serif;
}

body{
    background:#f4f6f9;
    color:#333;
}


nav{
    position:fixed;
    top:0;
    width:100%;
    background:#23395d;
    padding:15px 8%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    z-index:1000;
}

.logo{
    color:white;
    font-size:24px;
    font-weight:700;
}

nav ul{
    display:flex;
    list-style:none;
}

nav ul li{
    margin-left:25px;
}

nav ul li a{
    color:white;
    text-decoration:none;
    transition:.3s;
}

nav ul li a:hover{
    color:#ff4b5c;
}



.hero{
    height:100vh;
    background:linear-gradient(rgba(35,57,93,.85),
    rgba(35,57,93,.85)),
    url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3');
    background-size:cover;
    background-position:center;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
    color:white;
}

.hero-content img{
    width:180px;
    height:180px;
    border-radius:50%;
    border:6px solid white;
    margin-bottom:20px;
}

.hero h1{
    font-size:52px;
}

.hero p{
    font-size:20px;
    margin-top:10px;
}

.btn{
    display:inline-block;
    margin-top:25px;
    padding:12px 28px;
    background:#ff4b5c;
    color:white;
    text-decoration:none;
    border-radius:30px;
}



section{
    padding:90px 10%;
}

.section-title{
    text-align:center;
    margin-bottom:50px;
}

.section-title h2{
    font-size:38px;
    color:#23395d;
}



.about{
    background:white;
}

.about p{
    text-align:center;
    max-width:900px;
    margin:auto;
    line-height:1.8;
}



.skills-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
}

.skill-card{
    background:white;
    padding:25px;
    border-radius:15px;
    text-align:center;
    box-shadow:0 5px 20px rgba(0,0,0,.1);
}

.skill-card h3{
    color:#23395d;
}



.projects{
    background:white;
}

.project-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
    gap:25px;
}

.project-card{
    background:#f8f9fc;
    padding:25px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
}

.project-card h3{
    color:#23395d;
    margin-bottom:15px;
}



.timeline{
    border-left:4px solid #23395d;
    padding-left:30px;
}

.timeline-item{
    margin-bottom:40px;
}

.timeline-item h3{
    color:#23395d;
}


.edu-card{
    background:white;
    padding:25px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
    margin-bottom:20px;
}


.contact{
    background:#23395d;
    color:white;
}

.contact-container{
    max-width:700px;
    margin:auto;
}

.contact form{
    display:flex;
    flex-direction:column;
}

.contact input,
.contact textarea{
    margin:10px 0;
    padding:15px;
    border:none;
    border-radius:8px;
}

.contact button{
    padding:15px;
    border:none;
    background:#ff4b5c;
    color:white;
    cursor:pointer;
    border-radius:8px;
}

/* Footer */

footer{
    background:#17263d;
    color:white;
    text-align:center;
    padding:20px;
}

@media(max-width:768px){

.hero h1{
    font-size:38px;
}

nav ul{
    gap:12px;
    flex-wrap:wrap;
}

}

</style>
</head>

