<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Registration System</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#eef3ff;
    padding:20px;
}

.container{
    display:flex;
    gap:20px;
}

.left{
    width:38%;
    background:white;
    padding:25px;
    border-radius:10px;
    box-shadow:0 0 12px rgba(0,0,0,.2);
}

.right{
    width:62%;
    background:white;
    padding:25px;
    border-radius:10px;
    box-shadow:0 0 12px rgba(0,0,0,.2);
    overflow-x:auto;
}

h2{
    text-align:center;
    color:#003366;
    margin-bottom:20px;
}

label{
    font-weight:bold;
}

input,
select,
textarea{
    width:100%;
    padding:10px;
    margin-top:5px;
    margin-bottom:15px;
    border:1px solid #ccc;
    border-radius:5px;
    font-size:15px;
}

.gender{
    display:flex;
    gap:20px;
    margin-bottom:15px;
}

.gender label{
    font-weight:normal;
}

.gender input{
    width:auto;
}

.buttons{
    display:flex;
    justify-content:space-between;
}

button{
    width:48%;
    padding:12px;
    border:none;
    color:white;
    cursor:pointer;
    border-radius:5px;
    font-size:16px;
}

.submit{
    background:#007bff;
}

.submit:hover{
    background:#0056b3;
}

.reset{
    background:#dc3545;
}

.reset:hover{
    background:#b52b3a;
}

table{
    width:100%;
    border-collapse:collapse;
}

table th,
table td{
    border:1px solid #ccc;
    padding:10px;
    text-align:center;
}

table th{
    background:#007bff;
    color:white;
}

.editBtn{
    background:green;
    color:white;
    border:none;
    padding:6px 12px;
    cursor:pointer;
    border-radius:5px;
    margin-right:5px;
}

.deleteBtn{
    background:red;
    color:white;
    border:none;
    padding:6px 12px;
    cursor:pointer;
    border-radius:5px;
}

</style>

</head>

<body>

<div class="container">

<div class="left">

<h2>Registration Form</h2>

<form id="studentForm">

<label>First Name</label>
<input type="text" id="fname">

<label>Last Name</label>
<input type="text" id="lname">

<label>Email</label>
<input type="email" id="email">

<label>Mobile Number</label>
<input type="text" id="mobile">

<label>Date of Birth</label>
<input type="date" id="dob">

<label>Gender</label>

<div class="gender">

<label>
<input type="radio" name="gender" value="Male">
Male
</label>

<label>
<input type="radio" name="gender" value="Female">
Female
</label>

<label>
<input type="radio" name="gender" value="Other">
Other
</label>

</div>

<label>Course</label>

<select id="course">

<option value="">Select Course</option>

<option>Computer Science</option>

<option>Mechanical</option>

<option>Civil</option>

<option>Information Technology</option>

<option>BCA</option>

<option>B.Sc Computer Science</option>

</select>

<label>Address</label>

<textarea id="address" rows="3"></textarea>

<div class="buttons">

<button type="submit" class="submit">
Submit
</button>

<button type="reset" class="reset">
Reset
</button>

</div>

</form>

</div>

<div class="right">

<h2>Registered Students</h2>

<table id="studentTable">

<thead>

<tr>

<th>S.No</th>

<th>Name</th>

<th>Email</th>

<th>Mobile</th>

<th>Course</th>

<th>Actions</th>

</tr>

</thead>

<tbody>

</tbody>

</table>

</div>

</div>

<script>

let students=[];

let editIndex=-1;
document.getElementById("studentForm").addEventListener("submit", function(e){

    e.preventDefault();

    let fname=document.getElementById("fname").value.trim();
    let lname=document.getElementById("lname").value.trim();
    let email=document.getElementById("email").value.trim();
    let mobile=document.getElementById("mobile").value.trim();
    let dob=document.getElementById("dob").value;
    let course=document.getElementById("course").value;
    let address=document.getElementById("address").value.trim();

    let gender=document.querySelector('input[name="gender"]:checked');

    let namePattern=/^[A-Za-z ]+$/;
    let emailPattern=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    let mobilePattern=/^[0-9]{10}$/;

    if(!namePattern.test(fname)){
        alert("Enter a valid First Name");
        return;
    }

    if(!namePattern.test(lname)){
        alert("Enter a valid Last Name");
        return;
    }

    if(!emailPattern.test(email)){
        alert("Enter a valid Email");
        return;
    }

    if(!mobilePattern.test(mobile)){
        alert("Enter a valid 10-digit Mobile Number");
        return;
    }

    if(dob==""){
        alert("Select Date of Birth");
        return;
    }

    if(!gender){
        alert("Select Gender");
        return;
    }

    if(course==""){
        alert("Select Course");
        return;
    }

    if(address==""){
        alert("Enter Address");
        return;
    }

    let student={

        firstName:fname,
        lastName:lname,
        email:email,
        mobileNumber:mobile,
        dateOfBirth:dob,
        gender:gender.value,
        course:course,
        address:address

    };

    if(editIndex==-1){

        students.push(student);

    }
    else{

        students[editIndex]=student;

        editIndex=-1;

    }

    displayStudents();

    alert("Registration Successful");

    document.getElementById("studentForm").reset();

});



function displayStudents(){

    let tbody=document.querySelector("#studentTable tbody");

    tbody.innerHTML="";

    students.forEach(function(student,index){

        tbody.innerHTML+=`

<tr>

<td>${index+1}</td>

<td>${student.firstName} ${student.lastName}</td>

<td>${student.email}</td>

<td>${student.mobileNumber}</td>

<td>${student.course}</td>

<td>

<button
class="editBtn"
onclick="editStudent(${index})">

Edit

</button>

<button
class="deleteBtn"
onclick="deleteStudent(${index})">

Delete

</button>

</td>

</tr>

`;

    });

}
function editStudent(index){

    let student = students[index];

    document.getElementById("fname").value = student.firstName;
    document.getElementById("lname").value = student.lastName;
    document.getElementById("email").value = student.email;
    document.getElementById("mobile").value = student.mobileNumber;
    document.getElementById("dob").value = student.dateOfBirth;
    document.getElementById("course").value = student.course;
    document.getElementById("address").value = student.address;

    document.querySelector(
        `input[name="gender"][value="${student.gender}"]`
    ).checked = true;

    editIndex = index;

}



function deleteStudent(index){

    let choice = confirm("Are you sure you want to delete this student?");

    if(choice){

        students.splice(index,1);

        displayStudents();

        if(editIndex == index){
            document.getElementById("studentForm").reset();
            editIndex = -1;
        }

    }

}

</script>

</body>
</html>
